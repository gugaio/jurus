<div id="<%= dom_id post %>">
  <p>
    <strong>Title:</strong>
    <%= post.title %>
  </p>

  <p>
    <strong>Resume:</strong>
    <%= post.resume %>
  </p>

  <p>
    <strong>Body:</strong>
    <%= post.body %>
  </p>

  <p>
    <strong>Category:</strong>
    <%= post.category %>
  </p>

  <p>
    <strong>Logo:</strong>
    <%= post.logo %>
  </p>

  <p>
    <strong>Banner:</strong>
    <%= post.banner %>
  </p>

</div>
